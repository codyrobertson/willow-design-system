{
  "name": "willow-design-system",
  "version": "0.1.0",
  "description": "A modern design system for React applications built with Tailwind CSS",
  "author": "Willow Design System Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/willow-design-system"
  },
  "homepage": "https://willow-design-system.vercel.app",
  "keywords": [
    "react",
    "design-system",
    "components",
    "tailwindcss",
    "shadcn",
    "ui"
  ],
  "files": [
    "dist",
    "src/components",
    "lib",
    "registry.json",
    "registry",
    "components.json"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./registry": "./registry.json",
    "./styles": "./dist/index.css"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:types": "tsc --noEmit --skipLibCheck",
    "check:all": "node scripts/check-all-errors.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-lib": "tsup",
    "build-registry": "node scripts/build-registry.js",
    "prepublishOnly": "npm run build-lib",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --passWithNoTests",
    "test:update": "jest --updateSnapshot",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "prepare-fonts": "node scripts/prepare-fonts.js",
    "build:all": "npm run prepare-fonts && npm run build && npm run build-storybook && npm run build-registry",
    "build:vercel": "node scripts/build-for-vercel.js",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "focus-trap-react": "^11.0.4",
    "lucide-react": "^0.517.0",
    "next": "15.3.4",
    "next-themes": "^0.4.6",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@storybook/addon-actions": "^9.0.8",
    "@storybook/addon-docs": "^9.0.12",
    "@storybook/addon-onboarding": "^9.0.12",
    "@storybook/nextjs": "^9.0.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.10.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "eslint-plugin-storybook": "^9.0.12",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "postcss": "^8.5.6",
    "storybook": "^9.0.12",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.0.1",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^3.0.0"
  }
}
