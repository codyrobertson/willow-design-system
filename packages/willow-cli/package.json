{
  "name": "willow-cli",
  "version": "0.6.22",
  "description": "CLI for installing Willow Design System components",
  "type": "module",
  "bin": {
    "willow": "bin/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "tsx src/cli.ts add button",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "willow",
    "design-system",
    "shadcn",
    "ui",
    "components",
    "cli"
  ],
  "author": "Willow Design System Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "didyoumean": "^1.2.2",
    "glob": "^10.3.10",
    "ora": "^7.0.1"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
