6.448 75.1601 26.064 74.2854 25.296C73.4321 24.528 73.0054 23.2907 73.0054 21.584V3.6H77.2294V20.944C77.2294 21.8827 77.6241 22.352 78.4134 22.352C78.7334 22.352 79.0534 22.32 79.3734 22.256L79.4694 26.096C78.8934 26.3307 78.2428 26.448 77.5174 26.448ZM85.6899 26.448C84.4099 26.448 83.3326 26.064 82.4579 25.296C81.6046 24.528 81.1779 23.2907 81.1779 21.584V3.6H85.4019V20.944C85.4019 21.8827 85.7966 22.352 86.5859 22.352C86.9059 22.352 87.2259 22.32 87.5459 22.256L87.6419 26.096C87.0659 26.3307 86.4153 26.448 85.6899 26.448ZM96.9344 26.48C95.3771 26.48 93.9478 26.1173 92.6464 25.392C91.3664 24.6453 90.3531 23.632 89.6064 22.352C88.8598 21.072 88.4864 19.664 88.4864 18.128C88.4864 16.592 88.8598 15.184 89.6064 13.904C90.3531 12.624 91.3664 11.6213 92.6464 10.896C93.9478 10.1493 95.3771 9.776 96.9344 9.776C98.4918 9.776 99.9104 10.1493 101.19 10.896C102.492 11.6213 103.505 12.624 104.23 13.904C104.977 15.184 105.35 16.592 105.35 18.128C105.35 19.664 104.977 21.072 104.23 22.352C103.505 23.632 102.492 24.6453 101.19 25.392C99.9104 26.1173 98.4918 26.48 96.9344 26.48ZM96.9344 22.544C98.0864 22.544 99.0464 22.1387 99.8144 21.328C100.582 20.5173 100.966 19.4507 100.966 18.128C100.966 16.8267 100.582 15.7707 99.8144 14.96C99.0464 14.128 98.0864 13.712 96.9344 13.712C95.7611 13.712 94.7904 14.128 94.0224 14.96C93.2544 15.7707 92.8704 16.8267 92.8704 18.128C92.8704 19.472 93.2544 20.5493 94.0224 21.36C94.7904 22.1493 95.7611 22.544 96.9344 22.544ZM105.733 10.256H109.989L112.069 20.656L113.893 14.608H117.541L119.365 20.656L121.445 10.256H125.701L121.861 26H117.669L115.717 19.408L113.765 26H109.605L105.733 10.256Z\"\n            fill={isDark ? 'url(#paint_letters_gradient)' : '#312F37'}\n          />\n        </g>\n      )}\n\n      {/* Gradient Definitions */}\n      <defs>\n        <linearGradient\n          id=\"paint_letters_gradient\"\n          x1=\"81.877\"\n          y1=\"-40.8687\"\n          x2=\"81.877\"\n          y2=\"69.6266\"\n          gradientUnits=\"userSpaceOnUse\"\n        >\n          <stop offset=\"0.313079\" stopColor=\"white\" />\n          <stop offset=\"1\" stopColor=\"white\" stopOpacity=\"0\" />\n        </linearGradient>\n        <linearGradient\n          id=\"paint0_linear_light\"\n          x1=\"14.9389\"\n          y1=\"0.0610352\"\n          x2=\"14.9389\"\n          y2=\"29.9388\"\n          gradientUnits=\"userSpaceOnUse\"\n        >\n          <stop stopColor=\"white\" />\n          <stop offset=\"1\" stopColor=\"white\" stopOpacity=\"0.6\" />\n        </linearGradient>\n        <linearGradient\n          id=\"paint0_linear_dark\"\n          x1=\"14.9389\"\n          y1=\"0.0610352\"\n          x2=\"14.9389\"\n          y2=\"29.9388\"\n          gradientUnits=\"userSpaceOnUse\"\n        >\n          <stop stopColor=\"#956EFB\" />\n          <stop offset=\"1\" stopColor=\"#956EFB\" stopOpacity=\"0.5\" />\n        </linearGradient>\n      </defs>\n    </svg>\n  );\n  }\n);\nLogo.displayName = 'Logo';",
