      "content": "import React from 'react'\n\nexport interface LogoProps extends React.SVGProps<SVGSVGElement> {\n  /**\n   * Size of the rendered logo.\n   */\n  size?: 'sm' | 'md' | 'lg'\n  /**\n   * Which part of the logo to show.\n   *  - \"logomark\" | \"icon\": only the icon\n   *  - \"wordmark\": only the lettering\n   *  - \"full\": logomark + wordmark\n   */\n  lockup?: 'logomark' | 'icon' | 'wordmark' | 'full'\n  /**\n   * Theme variant\n   */\n  variant?: 'light' | 'dark'\n}\n\nconst SIZE_MAP = {\n  sm: { width: 94, height: 24, iconSize: 24 },\n  md: { width: 126, height: 32, iconSize: 32 },\n  lg: { width: 157, height: 40, iconSize: 40 }\n} as const\n\n/**\n * Willow Design System logo.\n */\nexport const Logo = React.forwardRef<SVGSVGElement, LogoProps>(\n  ({ size = 'md', lockup = 'full', variant = 'light', className, ...props }, ref) => {\n  const isDark = variant === 'dark'\n  const { width, height, iconSize } = SIZE_MAP[size]\n  const iconColor = isDark ? '#171717' : '#ffffff'\n  const iconBgColor = isDark ? '#f5f5f5' : 'rgba(255, 255, 255, 0.2)'\n\n  // Calculate viewBox based on lockup\n  const viewBoxWidth = lockup === 'logomark' || lockup === 'icon' ? 30 : 132\n  const viewBoxHeight = lockup === 'logomark' || lockup === 'icon' ? 30 : 32\n\n  return (\n    <svg\n      ref={ref}\n      width={lockup === 'logomark' || lockup === 'icon' ? iconSize : width}\n      height={lockup === 'logomark' || lockup === 'icon' ? iconSize : height}\n      viewBox={`0 0 ${viewBoxWidth} ${viewBoxHeight}`}\n      fill=\"none\"\n      xmlns=\"http://www.w3.org/2000/svg\"\n      role=\"img\"\n      aria-label=\"Willow logo\"\n      className={className}\n      {...props}\n    >\n      {/* Logomark */}\n      {lockup !== 'wordmark' && (\n        <g>\n          {isDark ? (\n            // Dark variant - white background\n            <>\n              <path \n                d=\"M0 14.9999C0 6.74941 6.68838 0.0610352 14.9389 0.0610352C23.1894 0.0610352 29.8778 6.74941 29.8778 14.9999C29.8778 23.2505 23.1894 29.9388 14.9389 29.9388C6.68838 29.9388 0 23.2505 0 14.9999Z\" \n                fill=\"url(#paint0_linear_light)\"\n              />\n              <path \n                d=\"M17.9281 19.4032C19.5786 21.054 19.5786 23.73 17.9281 25.3808C16.2773 27.0316 13.6004 27.0316 11.9496 25.3808C10.2993 23.7301 10.2993 21.054 11.9496 19.4032L14.9389 16.414L17.9281 19.4032Z\" \n                fill=\"#775DF9\"\n              />\n              <path \n                d=\"M4.55801 12.0107C6.20876 10.3604 8.88484 10.3604 10.5355 12.0107L13.5248 14.9999L10.5355 17.9892C8.88481 19.6397 6.20879 19.6397 4.55801 17.9892C2.90727 16.3384 2.90727 13.6615 4.55801 12.0107Z\" \n                fill=\"#775DF9\"\n              />\n              <path \n                d=\"M19.3422 12.0107C20.9929 10.3603 23.669 10.3604 25.3197 12.0107C26.9704 13.6615 26.9704 16.3384 25.3197 17.9892C23.669 19.6397 20.9929 19.6397 19.3422 17.9892L16.3529 14.9999L19.3422 12.0107Z\" \n                fill=\"#775DF9\"\n              />\n              <path \n                d=\"M11.9496 4.61906C13.6004 2.96829 16.2773 2.96829 17.9281 4.61906C19.5786 6.26983 19.5786 8.94587 17.9281 10.5966L14.9389 13.5859L11.9496 10.5966C10.2993 8.9459 10.2993 6.26979 11.9496 4.61906Z\" \n                fill=\"#775DF9\"\n              />\n            </>\n          ) : (\n            // Light variant - purple background\n            <>\n              <path \n                d=\"M0 14.9999C0 6.74941 6.68838 0.0610352 14.9389 0.0610352C23.1894 0.0610352 29.8778 6.74941 29.8778 14.9999C29.8778 23.2505 23.1894 29.9388 14.9389 29.9388C6.68838 29.9388 0 23.2505 0 14.9999Z\" \n                fill=\"url(#paint0_linear_dark)\"\n              />\n              <path \n                fillRule=\"evenodd\" \n                clipRule=\"evenodd\" \n                d=\"M18.9602 17.7297C20.4678 19.2373 22.9121 19.2373 24.4197 17.7297C25.9272 16.2221 25.9272 13.7778 24.4197 12.2702C22.9121 10.7626 20.4678 10.